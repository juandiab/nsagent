NSAGENT_ENCRYPTION_KEY=replace_with_generated_fernet_key
JWT_SECRET_KEY=replace_with_random_secret
# Set by the web installer on first setup (bootstrap only; login uses MongoDB after that)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=

# Deploy mode: prod = compiled stack (recommended); dev = hot reload for local hacking
NSAGENT_DEPLOY_MODE=prod

# Public hostname (nginx TLS termination — copy SSL files to SSL_CERTS_PATH)
NGINX_HOSTNAME=jpilot.nexxus-tech.com
SSL_CERTS_PATH=./nginx/ssl

# Nexxus licensing API base URL (license sync)
# NEXXUS_LICENSING_BASE_URL=https://nexxus-tech.com
# Background POST /licensing/sync interval in seconds (default 86400 = daily)
# LICENSE_SYNC_INTERVAL_SECONDS=86400

# Stack Calibration Studio (Send to Calibration feedback)
# NEXXUS_CALIBRATION_BASE_URL=https://scstudio.nexxus-tech.com
# Local dev with scstudio docker compose: http://host.docker.internal:8090
# CALIBRATION_SYNC_ENABLED=true

# Frontend API base URL (must match nginx /api/ proxy prefix)
VITE_API_BASE_URL=https://jpilot.nexxus-tech.com/api

# WebAuthn / passkeys (must match how users reach the UI)
WEBAUTHN_RP_ID=jpilot.nexxus-tech.com
WEBAUTHN_RP_NAME=NSAgent
WEBAUTHN_ORIGIN=https://jpilot.nexxus-tech.com

# Comma-separated browser origins allowed for API CORS (include how you open the UI)
CORS_ORIGINS=https://jpilot.nexxus-tech.com

# SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# When SMTP is not configured, log reset codes to backend logs (dev only)
PASSWORD_RESET_LOG_CODES=false
